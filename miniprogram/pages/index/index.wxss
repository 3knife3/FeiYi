/* 页面整体容器 */
.page-container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 轮播图 */
.banner{
  width: 100%;
  height: 400rpx;
}
.banner-swiper{
  width: 100%;
  height: 400rpx;
}
.banner-swiper-item{
  width: 100%;
  height: 400rpx;
  background-color: #f1f1f1;
}
.banner-image{
  width: 100%;
}

/* 重要通知 */
.notice-bar{
  margin-bottom: auto;
}
.notice-title{
  font-weight: bold;
  font-size: medium;
}

/* 最新公告 */
.latest-announcement-box {
  margin: 10rpx 0;
  border-radius: 8rpx;
  background-color: #ffffff;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  height: 75rpx;
}
.announce-tag {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  width: 80rpx;
  height: 60rpx;
  border-right: 3rpx solid #b0abab;
  padding-right: 10rpx;
  flex-shrink: 0;
}
.announce-tag text {
  font-size: 32rpx;
  font-weight: 900;
  color: #ef4444;
  line-height: 1.1;
  margin-left: 5rpx;
  letter-spacing: 2rpx;
}
.announce-content {
  font-size: 30rpx;
  color: #333333;
  flex: 1;
  line-height: 1.5;
}

/* 功能图 */
.function-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-around;
  padding: 30rpx 20rpx;
  background-color: #f5f5f5;
  margin-bottom: 20rpx;
}
.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 20%;
  margin-bottom: 20rpx;
}
.item-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  border: 2rpx solid #e5e5e5;
  background-color: #f9f9f9;
  padding: 10rpx;
  box-sizing: border-box;
  display: block;
  margin-bottom: 10rpx;
  object-fit: contain;
  /* 点击过渡动画 */
  transition: border-color 0.2s ease;
}
.grid-item:active .item-icon {
  border-color: #ed1325; 
}
.item-text {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

/* 地图图片 */
.map-box {
  padding: 20rpx;
  margin: 0 20rpx;
  background: #fff;
  border-radius: 16rpx;
}
.map-title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}
.map-preview {
  width: 100%;
  height: 400rpx;
  position: relative;
  overflow: hidden;
}
.map-img {
  width: 100%;
  height: 450rpx !important; 
  border-radius: 12rpx;
}
.map-tip {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}


/* 打卡弹窗 */
.check-popup{
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 9999;
  }
  .popup-mask{
    position: absolute;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.6);
  }
  .popup-content{
    position: relative;
    width: 90%;
    margin: 120rpx auto 0;
    background: #fff;
    border-radius: 24rpx;
    padding: 40rpx;
  }
  .popup-title{
    font-size: 36rpx;
    text-align: center;
    margin-bottom: 30rpx;
  }
  .point-grid{
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20rpx;
  }
  .point-item{
    height: 120rpx;
    background: #f2f2f2;
    border-radius: 16rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28rpx;
  }
  .point-item.active{
    background: #09BB07;
    color: #fff;
  }
  .score-info{
    text-align: center;
    margin: 30rpx 0;
    font-size: 28rpx;
  }
  .close-btn{
    width: 100%;
  }