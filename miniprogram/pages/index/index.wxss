/* 页面整体容器 */
.page-container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 轮播图 */
.banner{
  width: 100%;
  height: 400rpx;
}
.banner-swiper{
  width: 100%;
  height: 400rpx;
}
.banner-swiper-item{
  width: 100%;
  height: 400rpx;
  background-color: #f1f1f1;
}
.banner-image{
  width: 100%;
}

/* 功能图 */
.function-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-around;
  padding: 30rpx 20rpx;
  background-color: #f5f5f5;
  margin-bottom: 20rpx;
}
.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 20%;
  margin-bottom: 20rpx;
}
.item-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  border: 2rpx solid #e5e5e5;
  background-color: #f9f9f9;
  padding: 10rpx;
  box-sizing: border-box;
  display: block;
  margin-bottom: 10rpx;
  object-fit: contain;
  /* 点击过渡动画 */
  transition: border-color 0.2s ease;
}
.grid-item:active .item-icon {
  border-color: #ed1325; 
}
.item-text {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

/* 地图图片 */
.map-box {
  padding: 20rpx;
  margin: 0 20rpx;
  background: #fff;
  border-radius: 16rpx;
}
.map-title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}
.map-preview {
  width: 100%;
  height: 300rpx;
  position: relative;
}
.map-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 12rpx;
}
.map-tip {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}