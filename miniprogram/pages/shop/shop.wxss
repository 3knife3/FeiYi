/* pages/shop/shop.wxss */
/* 定位到label并修改颜色 */
.custom-score-cell .van-cell__label {
  color: #FF7800 !important; 
  font-size: 12px; 
}
/* 兑换弹窗遮罩层 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

/* 兑换弹窗内容 */
.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  box-sizing: border-box;
  z-index: 1000;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 20rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #333;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 30rpx;
}

/* 高亮显示积分和商品名 */
.cost-text {
  color: #ff4444;
  font-weight: bold;
}
.name-text {
  color: #1989fa;
  font-weight: bold;
}

/* 兑换按钮组 */
.modal-btn-group {
  display: flex;
  gap: 20rpx;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.confirm-btn {
  background: #ff4444;
  color: #fff;
}

/* 商品栏 */
.task-wrap {
  padding: 20rpx;
  /* 核心：弹性布局让按钮均匀分布 */
  display: flex;
  align-items: center; /* 垂直居中 */
  box-sizing: border-box;
}

/* 适配van-button样式，统一按钮宽度+高度 */
.task-wrap .van-button {
  flex: 1; /* 三个按钮平分宽度 */
  height: 70rpx; /* 统一按钮高度，更美观 */
  font-size: 26rpx; /* 适配移动端字体大小 */
  border-radius: 8rpx; /* 圆角更协调 */
}


.goods-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.goods-item {
  width: calc(50% - 10rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 15rpx;
  box-sizing: border-box;
}
.goods-img {
  width: 100%;
  height: auto;
  border-radius: 12rpx;
  display: block;
}
.goods-name {
  font-size: 28rpx;
  margin-top: 15rpx;
  color: #333;
}
.goods-cost {
  color: #ff4444;
  font-size: 26rpx;
  margin-top: 6rpx;
}
.rule {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  padding: 30rpx;
}


/* 分享、打卡弹窗样式 */
.popup-content {
  width: 600rpx;
  padding: 40rpx;
  text-align: center;
  position: relative;
  padding-top: 20rpx;
}
.popup-close {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 36rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 50%;
  /* 点击反馈 */
  touch-action: manipulation;
}
.popup-close:active {
  background: #ff4444;
  color: #fff;
}
.popup-content .title {
  font-size: 36rpx;
  font-weight: bold;
}

.popup-content .desc {
  margin: 20rpx 0;
  font-size: 28rpx;
}

.popup-content .info {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999;
}