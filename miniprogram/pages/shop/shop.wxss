/* pages/shop/shop.wxss  */
/* 顶部积分标签颜色 */
.custom-score-cell .van-cell__label {
  color: #FF7800;
  font-size: 24rpx;
}

/* 兑换弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
}
.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  box-sizing: border-box;
  z-index: 1000;
}
.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 20rpx;
}
.modal-desc {
  font-size: 28rpx;
  color: #333;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 30rpx;
}
.cost-text {
  color: #ff4444;
  font-weight: bold;
}
.name-text {
  color: #1989fa;
  font-weight: bold;
}
.modal-btn-group {
  display: flex;
  gap: 20rpx;
}
.cancel-btn, .confirm-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}
.cancel-btn {
  background: #f5f5f5;
  color: #666;
}
.confirm-btn {
  background: #ff4444;
  color: #fff;
}

/* 任务按钮栏 */
.task-wrap {
  padding: 20rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}
.task-wrap .van-button {
  flex: 1;
  height: 70rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
}

/* 商品列表 */
.goods-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between; /* 使用space-between自动分配间隙 */
  padding: 0 5rpx;
  box-sizing: border-box;
}

.goods-item {
  width: calc(50% - 15rpx); /* 减去间隙的一半，间隙越大减的越多 */
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 15rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.goods-img {
  width: 100% !important;
  height: 200rpx !important;
  border-radius: 12rpx;
  display: block;
  aspect-ratio: 1 / 1; /* 设置图片为正方形，保持统一比例 */
  object-fit: cover; /* 图片填充方式 */
}

.goods-name {
  font-size: 28rpx;
  margin-top: 15rpx;
  color: #333;
  text-align: center;
  width: 100%; /* 确保文字换行 */
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2; /* 最多显示2行 */
  -webkit-box-orient: vertical;
}

.goods-cost {
  color: #ff4444;
  font-size: 26rpx;
  margin-top: 6rpx;
  text-align: center;
  font-weight: bold; /* 价格加粗更醒目 */
  width: 100%; /* 确保价格占满宽度 */
}
.rule {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  padding: 30rpx;
}

/* 通用弹窗样式（签到、分享 用这个）*/
.popup-content {
  width: 580rpx;
  padding: 50rpx 40rpx;
  text-align: center;
  position: relative;
  border-radius: 24rpx;
  background: #fff;
}

/* 关闭按钮 × */
.popup-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  font-size: 32rpx;
  color: #999;
  background: #f5f5f5;
  border-radius: 50%;
}
.popup-close:active {
  background: #ff4d4f;
  color: #fff;
}

/* 标题 / 描述 / 小字 */
.popup-content .title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}
.popup-content .desc {
  margin: 10rpx 0 30rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}
.popup-content .info {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #999;
}

/* 分享弹窗 美化升级 */
/*  you 分享弹窗  */
.share-card {
  padding: 50rpx 35rpx !important;
  text-align: center !important;
  box-sizing: border-box !important;
  position: relative !important;
}

/* 关闭按钮 */
.share-card .popup-close {
  position: absolute !important;
  top: 25rpx !important;
  right: 30rpx !important;
  font-size: 40rpx !important;
  color: #888 !important;
}

/* 标题 */
.share-card .title {
  font-size: 44rpx !important;
  font-weight: bold !important;
  color: #1677ff !important;
  margin-bottom: 25rpx !important;
}

/* 描述 */
.share-card .desc {
  font-size: 28rpx !important;
  color: #555 !important;
  margin-bottom: 35rpx !important;
  line-height: 1.6 !important;
}

/* 底部小字 */
.share-card .tip {
  font-size: 23rpx !important;
  color: #999 !important;
  margin-top: 20rpx !important;
}

/* 打卡弹窗 */
.check-popup {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

/* 半透明背景 */
.popup-mask {
  position: absolute;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.45);
}

/* 弹窗主体 */
.popup-content {
  width: 88%;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 50rpx 40rpx;
  box-sizing: border-box;
  position: relative;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
}

/* 标题 */
.popup-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 40rpx;
}

/* 景点网格布局（3列 对称美观） */
.point-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
}

/* 单个景点按钮 */
.point-item {
  width: 31%;
  height: 88rpx;
  background: #f7f8fa;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  box-sizing: border-box;
}

/* 已打卡样式（绿色） */
.point-item.active {
  background: #1677ff;
  color: #fff;
}

/* 积分信息 */
.score-info {
  text-align: center;
  font-size: 28rpx;
  color: #1677ff;
  margin: 36rpx 0 20rpx;
  font-weight: 500;
}

/* 关闭按钮 */
.close-btn {
  width: 100%;
  height: 80rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  margin-top: 10rpx;
}