/* 页面容器 */
.container {
    padding: 20rpx;
    background: #f5f5f5;
    min-height: 100vh;
    box-sizing: border-box;
  }
  
  /* 栏目 */
  .tabs {
    display: flex;
    justify-content: space-around;
    margin-bottom: 30rpx;
    width: 100%;
  }
  /* 标签 */
  .tab {
    font-size: 32rpx;
    color: #666;
    padding: 15rpx 30rpx;
    cursor: pointer;
    border-radius: 60rpx;
  }
  /* 栏目标签点击后高亮显示 */
  .tab.active {
    background: #00c1de;
    color: #fff;
    border-radius: 60rpx;
  }
  
  /* 轮播 */
  .swiper {
    height: 900rpx;
    border-radius: 60rpx;
    overflow: hidden;
    width: 100%;
  }
  /* 轮播图片 */
  .swiper-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  
  /* 描述 */
  .content-box {
    margin-top: 30rpx;
    padding: 20rpx;
    background: #fff;
    border-radius: 12rpx;
    box-sizing: border-box;
    width: 100%;
  }
  /* 描述标题 */
  .title {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
    display: block;
    margin-bottom: 10rpx;
  }
  /* 描述详细介绍 */
  .desc {
    font-size: 28rpx;
    color: #666;
    line-height: 1.6;
  }