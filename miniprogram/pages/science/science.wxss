.container {
    padding: 20rpx;
    background: #f5f5f5;
    min-height: 100vh;
    /* 新增：确保容器布局正常，子元素对齐 */
    box-sizing: border-box;
  }
  
  .tabs {
    display: flex;
    justify-content: space-around;
    margin-bottom: 30rpx;
    /* 新增：兼容不同设备的布局稳定性 */
    width: 100%;
  }
  
  .tab {
    font-size: 32rpx;
    color: #666;
    padding: 10rpx 20rpx;
    border-radius: 20rpx;
    /* 新增：点击区域更友好，鼠标悬浮提示 */
    cursor: pointer;
  }
  
  .tab.active {
    background: #00c1de;
    color: #fff;
  }
  
  .swiper {
    height: 400rpx; /* 核心：固定轮播图高度，确保图片显示 */
    border-radius: 20rpx;
    overflow: hidden;
    /* 新增：防止swiper组件默认样式干扰 */
    width: 100%;
  }
  
  .swiper-image {
    width: 100%;
    height: 100%;
    object-fit: cover; /* 核心：保持图片比例，不拉伸变形 */
    /* 新增：兼容低版本微信基础库 */
    display: block;
  }
  
  .content-box {
    margin-top: 30rpx;
    padding: 20rpx;
    background: #fff;
    border-radius: 12rpx;
    /* 新增：防止文字溢出 */
    box-sizing: border-box;
    width: 100%;
  }
  
  .title {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
    display: block;
    margin-bottom: 10rpx;
  }
  
  .desc {
    font-size: 28rpx;
    color: #666;
    line-height: 1.6;
    /* 新增：优化文字排版 */
    display: block;
  }