.container {
    padding: 20rpx;
    background: #f5f5f5;
    min-height: 100vh;
  }
  
  .tabs {
    display: flex;
    justify-content: space-around;
    margin-bottom: 30rpx;
  }
  
  .tab {
    font-size: 32rpx;
    color: #666;
    padding: 10rpx 20rpx;
    border-radius: 20rpx;
  }
  
  .tab.active {
    background: #00c1de;
    color: #fff;
  }
  
  .swiper {
    height: 400rpx;
    border-radius: 20rpx;
    overflow: hidden;
  }
  
  .swiper-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .content-box {
    margin-top: 30rpx;
    padding: 20rpx;
    background: #fff;
    border-radius: 12rpx;
  }
  
  .title {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
    display: block;
    margin-bottom: 10rpx;
  }
  
  .desc {
    font-size: 28rpx;
    color: #666;
    line-height: 1.6;
  }