<view class="container">

    <!-- 栏目 -->
    <view class="tabs">
        <view 
            class="tab {{currentTab === 'scenery' ? 'active' : ''}}"
            bindtap="switchTab"
            data-tab="scenery"
          >
            景点</view>
          <view 
            class="tab {{currentTab === 'food' ? 'active' : ''}}"
            bindtap="switchTab"
            data-tab="food"
          >
            美食</view>
          <view 
           class="tab {{currentTab === 'entertainment' ? 'active' : ''}}"
            bindtap="switchTab"
            data-tab="entertainment"
          >
            特色</view>
    </view>

    <!-- 卡片列表 -->
    <view class="card-list">
        <block wx:for="{{bannerList}}" wx:key="id">
            <!-- 卡片 -->
            <view class="card-item" bindtap="openLongImage" data-id="{{item.id}}">
                <image src="{{item.image}}" class="card-bg"></image>
                <!-- 卡片文本 -->
                <view class="card-content">
                    <text class="card-title">{{item.title}}</text>
                    <text class="card-desc">{{item.content}}</text>
                </view>
            </view>
        </block>
    </view>

    <!-- 点击卡片详情弹窗 -->
    <view wx:if="{{showModal}}" class="long-modal" bindtap="closeLongImage">
        <scroll-view class="long-scroll" scroll-y>
            <image src="{{longImageUrl}}" class="long-img" mode="widthFix"></image>
        </scroll-view>
        <view class="quiz-btn" catchtap="openQuizModal">开始知识问答</view>
    </view>
    
    <!-- 弹窗2：知识问答 -->
<view wx:if="{{showQuizModal}}" class="quiz-modal" bindtap="closeQuizModal">
  <view class="quiz-box" catchtap="voidClick">
    <view class="quiz-title">{{currentQuiz.quizTitle}}</view>
    <view class="quiz-question">{{currentQuiz.quizQuestion}}</view>

    <view class="quiz-options">
      <view 
        wx:for="{{currentQuiz.quizOptions}}" 
        wx:key="index" 
        class="quiz-option {{selectedAnswer == index ? (Number(index) == currentQuiz.quizAnswer ? 'correct' : 'wrong') : ''}}"
        data-index="{{index}}"
        bindtap="checkAnswer"  
      >
        {{item}}
      </view>
    </view>

    <!-- 答对/答错提示 -->
    <view wx:if="{{selectedAnswer != null}}" class="quiz-result {{Number(selectedAnswer) == Number(currentQuiz['quizAnswer']) ? 'correct' : 'wrong'}}">
</view>

    <!-- 答案解析 -->
    <view wx:if="{{selectedAnswer != null}}" class="quiz-explain">
      {{currentQuiz.quizExplain}}
    </view>
  </view>
</view>

</view>