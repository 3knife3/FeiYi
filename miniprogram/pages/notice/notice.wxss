/* pages/notice/notice.wxss */
/* 页面全局样式，强制背景统一 */
page {
  background: #f5f5f5;
}
.container {
  padding: 20rpx;
}
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 35rpx;
  margin-bottom: 20rpx;
}
.head {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.bell {
  font-size: 32rpx;
  color: #ff7d00;
  margin-right: 14rpx;
}
.date {
  font-size: 28rpx;
  color: #999;
}
.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}
.content {
  font-size: 30rpx;
  line-height: 1.8;
  white-space: pre-wrap;
  color: #333;
  margin-bottom: 25rpx;
}
.foot {
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
  font-size: 26rpx;
  color: #666;
}

/* 加载更多 */
.load-box {
  padding: 30rpx 0;
  text-align: center;
}
.loading {
  color: #999;
}
.load-btn {
  color: #07c160;
  padding: 10rpx 25rpx;
  border: 1rpx solid #07c160;
  border-radius: 10rpx;
  display: inline-block;
}
.no-more {
  color: #ccc;
}