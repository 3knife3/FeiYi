/* 登录按钮 */
.login-btn-area {
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .login-btn {
    width: 200rpx;
    height: 80rpx;
    background: #01ccb6;
    color: #fff;
    border-radius: 10rpx;
  }
  
  /* 弹窗内部 */
  .login-dialog {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 20rpx 0;
  }
  
  /* 你的原有样式：avatar-wrapper */
  .avatar-wrapper {
    width: 120rpx !important;
    height: 120rpx !important;
    padding: 0 !important;
    background: transparent !important;
    border: none !important;
  }
  .avatar {
    width: 120rpx;
    height: 120rpx;
    border-radius: 50%;
  }
  
  /* 你的原有样式：weui-input */
  .weui-input {
    width: 80%;
    height: 70rpx;
    border: 1px solid #eee;
    border-radius: 8rpx;
    margin: 20rpx 0;
    text-align: center;
  }
  
  /* 提交按钮 */
  .submit-btn {
    width: 80%;
    height: 80rpx;
    background: #01ccb6;
    color: #fff;
    border-radius: 10rpx;
  }