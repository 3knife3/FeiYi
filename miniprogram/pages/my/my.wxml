<!--pages/login/login.wxml-->
<view class="container">

<!-- 登陆前：横向布局 + 整体可点击 -->
<block wx:if="{{!userInfo}}">
  <view class="login-before" bind:tap="goLogin">
    <image class="avatar-default" src="/images/login/DefaultAvatar.png"></image>
    <text class="login-text">你好，请登录！</text>
    <van-icon name="arrow" size="50rpx"/>
  </view>
</block>

<!-- 登录后 -->
<block wx:else>
  <view class="user-info-card">
    <view class="user-profile">
      <view class="user-row">
        <image class="avatar-user" src="{{userInfo.avatar}}" bind:tap="logout"></image>
        <view class="user-name">
          <view class="logout-txt">{{userInfo.name}}</view>
        </view>
      </view>
    </view>

    <view class="user-data">
      <view class="data-item">
        <text class="data-num">{{ userScore }}</text>
        <text class="data-label">积分</text>
      </view>
      <view class="data-item">
        <text class="data-label">碎片</text>
        <image 
          class="chip-icon" 
          src="cloud://cloud1-2gp5ez590981c671.636c-cloud1-2gp5ez590981c671-1383410318/fragment/拼图1234.png"
          mode="widthFix"
          bind:tap="previewChip"
          ></image>
      </view>
    </view>
  </view>
</block>

