<!-- 选项 -->
<view class="menu-list">
  <van-cell class="menu-item" title="积分兑换记录" is-link bind:tap="goToOrder" />
  <van-cell class="menu-item" title="关于我们" is-link bind:tap="showContact" />
  <van-dialog 
    title="关于我们" 
    message="本小程序由学生团队开发。" 
    show="{{showContact}}" 
    bind:confirm="onConfirm">
  </van-dialog>
</view>

</view>